# Backend Environment Variables Template

# Copy this file to .env and fill in your actual values

# NEVER commit the .env file to version control!



# For development (SQLite — legacy app models):

# DATABASE_URL=sqlite:///./healthcare.db



# For production / full 20-table schema (PostgreSQL):

DATABASE_URL=postgresql://healthcare:healthcare_dev@localhost:5432/healthcare



# Security - CRITICAL: Change this in production!

# Generate a strong secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"

SECRET_KEY=your-super-secret-key-here-change-in-production

ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=1440



# USDA FoodData Central — https://fdc.nal.usda.gov/api-key-signup.html

USDA_FDC_API_KEY=



# Gemini AI API Key

# Get from: https://makersuite.google.com/app/apikey

GEMINI_API_KEY=your_gemini_api_key_here



# Groq API Key — https://console.groq.com/

GROQ_API_KEY=your_groq_api_key_here



# DeepSeek API Key

DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Vercel AI Gateway — same key as EXPO_PUBLIC_AI_GATEWAY_API_KEY (required for web chat proxy)
AI_GATEWAY_API_KEY=your_ai_gateway_api_key_here



# CORS Configuration

# Comma-separated list of allowed origins

# Example: http://localhost:3000,https://yourdomain.com

ALLOWED_ORIGINS=http://localhost:8084,http://127.0.0.1:8084,http://192.168.1.9:8084



# File Upload Configuration

MAX_FILE_SIZE=10485760

UPLOAD_DIR=./uploads



# Paddle OCR microservice (run from project/paddle_ocr_backend: python run_paddle_ocr.py)

PADDLE_OCR_BASE=http://127.0.0.1:8001

PADDLE_OCR_PORT=8001

PADDLE_OCR_LANG=en

# PADDLE_OCR_TIMEOUT=900



# Email Configuration (Optional)

SMTP_HOST=smtp.gmail.com

SMTP_PORT=587

SMTP_USERNAME=

SMTP_PASSWORD=



# Telehealth — Zoom OAuth (User-managed app)

# Create app: https://marketplace.zoom.us/develop/create

# App type: General app → User-managed OAuth

# Add redirect URL: http://192.168.1.9:8000/zoom/oauth/callback (and localhost for PC)
# Scopes: user:read, meeting:write:meeting, meeting:read:meeting
# API base: https://api.zoom.us/v2/
# Setup script: python setup_zoom.py

ZOOM_CLIENT_ID=

ZOOM_CLIENT_SECRET=

ZOOM_REDIRECT_URI=http://192.168.1.9:8000/zoom/oauth/callback

ZOOM_OAUTH_FRONTEND_REDIRECT=http://192.168.1.9:8084

# Optional: user id of the doctor/host who connected Zoom (defaults to first connected account)

ZOOM_HOST_USER_ID=



# Legacy Server-to-Server (optional fallback for scheduled appointments only)

ZOOM_ACCOUNT_ID=

ZOOM_USER_ID=me



# Telehealth — Google Calendar + Meet (service account JSON path, calendar id)

GOOGLE_SERVICE_ACCOUNT_FILE=

GOOGLE_CALENDAR_ID=primary

