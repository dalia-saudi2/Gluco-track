# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# Database Configuration
# For development: sqlite:///./healthcare.db
# For production: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./healthcare.db

# Security - CRITICAL: Change this in production!
# Generate a strong secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# USDA FoodData Central — https://fdc.nal.usda.gov/api-key-signup.html
USDA_FDC_API_KEY=

# Gemini AI API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key — https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# DeepSeek API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# CORS Configuration
# Comma-separated list of allowed origins
# Example: http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:8082

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
